# CareOS environment configuration
# The demo runs fully offline on fixture data — these are only needed when
# connecting the production backend.

# Supabase (backend: auth, PostgreSQL + RLS, realtime, storage, edge functions)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# AI provider (server-side only — never expose in NEXT_PUBLIC_*)
AI_PROVIDER=anthropic
AI_API_KEY=

# Maps adapter (community planner)
NEXT_PUBLIC_MAPS_PROVIDER=mapbox
NEXT_PUBLIC_MAPS_API_KEY=
